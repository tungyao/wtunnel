+
+// SSL_CTX_set_chrome_ext_order sets the ClientHello extension emission order.
+// When chrome_fingerprint_mode is active and this list is non-empty, extensions
+// are emitted in this exact order; extensions not listed are skipped.
+void SSL_CTX_set_chrome_ext_order(SSL_CTX *ctx, const uint16_t *types,
+                                   size_t count) {
+  if (count > 32) count = 32;
+  ctx->chrome_ext_order_count = count;
+  for (size_t i = 0; i < count; i++) {
+    ctx->chrome_ext_order[i] = types[i];
+  }
+}
+
+// SSL_CTX_set_chrome_ec_point_formats sets the full ec_point_formats list
+// written into the ClientHello when chrome_fingerprint_mode is active.
+void SSL_CTX_set_chrome_ec_point_formats(SSL_CTX *ctx, const uint8_t *fmts,
+                                          size_t count) {
+  if (count > 8) count = 8;
+  ctx->chrome_ec_point_formats_count = count;
+  for (size_t i = 0; i < count; i++) {
+    ctx->chrome_ec_point_formats[i] = fmts[i];
+  }
+}
+
+// SSL_CTX_set_chrome_versions sets the exact supported_versions list written
+// into the ClientHello when chrome_fingerprint_mode is active.
+void SSL_CTX_set_chrome_versions(SSL_CTX *ctx, const uint16_t *versions,
+                                  size_t count) {
+  if (count > 8) count = 8;
+  ctx->chrome_versions_count = count;
+  for (size_t i = 0; i < count; i++) {
+    ctx->chrome_versions[i] = versions[i];
+  }
+}
+
 void SSL_CTX_set_permute_extensions(SSL_CTX *ctx, int enabled) {
   ctx->permute_extensions = !!enabled;
 }
