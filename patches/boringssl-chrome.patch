+// SSL_CTX_set_client_custom_ext_cb registers a callback invoked during
+// ClientHello assembly, after all standard extensions. The callback may append
+// additional TLS extensions by writing to |extensions| (a CBB whose parent
+// holds the extensions length-prefix). Return true to continue, false to abort.
+OPENSSL_EXPORT void SSL_CTX_set_client_custom_ext_cb(
+    SSL_CTX *ctx,
+    bool (*cb)(SSL *ssl, CBB *extensions, void *arg),
+    void *arg);
+
+// SSL_CTX_set_client_session_id_cb registers a callback invoked after the
+// legacy_session_id is filled with 32 random bytes during ClientHello
+// construction (TLS 1.3 compatibility mode). The callback may overwrite any
+// bytes of |session_id| in-place, e.g., to embed an identity marker.
+OPENSSL_EXPORT void SSL_CTX_set_client_session_id_cb(
+    SSL_CTX *ctx,
+    void (*cb)(SSL *ssl, uint8_t session_id[32], void *arg),
+    void *arg);
+
+// SSL_CTX_enable_chrome_fingerprint_mode enables Chrome-compatible ClientHello
+// layout: extension ordering matches Chrome, ec_point_formats includes
+// compressed formats. Use SSL_CTX_set_chrome_* functions to supply per-version
+// parameters parsed from a real Chrome capture.
+OPENSSL_EXPORT void SSL_CTX_enable_chrome_fingerprint_mode(SSL_CTX *ctx);
+
+// SSL_CTX_set_chrome_cipher_wire supplies the exact ClientHello cipher list
+// (all suites, in wire order) parsed from a Wireshark capture. When set and
+// chrome_fingerprint_mode is active, this list is written verbatim, bypassing
+// BoringSSL's internal cipher ordering. Maximum 32 entries.
+OPENSSL_EXPORT void SSL_CTX_set_chrome_cipher_wire(SSL_CTX *ctx,
+                                                    const uint16_t *ids,
+                                                    size_t count);
+
+// SSL_CTX_set_chrome_ext_order sets the ClientHello extension emission order.
+// When chrome_fingerprint_mode is active and this list is non-empty, extensions
+// are emitted in this exact order (by type ID); extensions not listed are not
+// emitted. Populate from ChromeFingerprint::extensions. Maximum 32 entries.
+OPENSSL_EXPORT void SSL_CTX_set_chrome_ext_order(SSL_CTX *ctx,
+                                                  const uint16_t *types,
+                                                  size_t count);
+
+// SSL_CTX_set_chrome_ec_point_formats sets the full ec_point_formats list
+// written verbatim into the ClientHello. Populate from
+// ChromeFingerprint::ec_point_formats. Maximum 8 entries.
+OPENSSL_EXPORT void SSL_CTX_set_chrome_ec_point_formats(SSL_CTX *ctx,
+                                                         const uint8_t *fmts,
+                                                         size_t count);
+
+// SSL_CTX_set_chrome_versions supplies the exact supported_versions list
+// (in wire order) to write into the ClientHello. Maximum 8 entries.
+OPENSSL_EXPORT void SSL_CTX_set_chrome_versions(SSL_CTX *ctx,
+                                                 const uint16_t *versions,
+                                                 size_t count);
+
