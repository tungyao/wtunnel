 OPENSSL_EXPORT void SSL_CTX_set_permute_extensions(SSL_CTX *ctx, int enabled);
 
+// SSL_CTX_set_client_custom_ext_cb registers a callback invoked during
+// ClientHello assembly, after all standard extensions. The callback may append
+// additional TLS extensions by writing to |extensions| (a CBB whose parent
+// holds the extensions length-prefix). Return true to continue, false to abort.
+OPENSSL_EXPORT void SSL_CTX_set_client_custom_ext_cb(
+    SSL_CTX *ctx,
+    bool (*cb)(SSL *ssl, CBB *extensions, void *arg),
+    void *arg);
+
+// SSL_CTX_set_client_session_id_cb registers a callback invoked after the
+// legacy_session_id is filled with 32 random bytes during ClientHello
+// construction (TLS 1.3 compatibility mode). The callback may overwrite any
+// bytes of |session_id| in-place, e.g., to embed an identity marker.
+OPENSSL_EXPORT void SSL_CTX_set_client_session_id_cb(
+    SSL_CTX *ctx,
+    void (*cb)(SSL *ssl, uint8_t session_id[32], void *arg),
+    void *arg);
+
+// SSL_CTX_enable_chrome_fingerprint_mode enables Chrome 146-compatible
+// ClientHello layout: TLS 1.3 cipher order (AES-256-GCM, CHACHA20, AES-128-GCM),
+// Chrome extension order, empty encrypt_then_mac extension, and suppressed
+// renegotiate extension (use SSL_CTX_set_chrome_extra_ciphers to inject SCSV).
+OPENSSL_EXPORT void SSL_CTX_enable_chrome_fingerprint_mode(SSL_CTX *ctx);
+
+// SSL_CTX_set_chrome_extra_ciphers appends |count| cipher suite IDs verbatim
+// to the ClientHello cipher list after all standard TLS 1.2 ciphers. Used to
+// inject RSA cipher suites and SCSV (0x00ff) for fingerprint matching.
+// Maximum 8 entries.
+OPENSSL_EXPORT void SSL_CTX_set_chrome_extra_ciphers(SSL_CTX *ctx,
+                                                      const uint16_t *ids,
+                                                      size_t count);
+
 // SSL_set_permute_extensions configures whether sockets on |ssl| should
 // permute extensions. For now, this is only implemented for the ClientHello.
 OPENSSL_EXPORT void SSL_set_permute_extensions(SSL *ssl, int enabled);
