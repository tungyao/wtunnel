diff --git a/ssl/internal.h b/ssl/internal.h
index 682acbf2..0191e498 100644
--- a/ssl/internal.h
+++ b/ssl/internal.h
@@ -3984,6 +3984,32 @@ struct ssl_ctx_st : public bssl::RefCounted<ssl_ctx_st> {
   // signal its sessions may be resumed across names in the server certificate.
   bool resumption_across_names_enabled : 1;
 
+  // client_custom_ext_cb, if non-null, is called during ClientHello assembly
+  // after all standard extensions. The callback may append additional TLS
+  // extensions to |extensions|. Returns true on success, false to abort.
+  bool (*client_custom_ext_cb)(SSL *ssl, CBB *extensions, void *arg) = nullptr;
+  void *client_custom_ext_arg = nullptr;
+
+  // client_session_id_cb, if non-null, is called after the legacy_session_id
+  // is filled with random bytes. The callback may overwrite any of the 32 bytes
+  // in |session_id| in-place (e.g., to embed an identity marker).
+  void (*client_session_id_cb)(SSL *ssl, uint8_t session_id[32], void *arg) = nullptr;
+  void *client_session_id_arg = nullptr;
+
+  // chrome_fingerprint_mode enables Chrome 146-compatible ClientHello layout:
+  //   - TLS 1.3 cipher order: AES-256-GCM-SHA384, CHACHA20-POLY1305, AES-128-GCM-SHA256
+  //   - Extension order matching Chrome 146 (SNI, ec_point_formats, supported_groups,
+  //     session_ticket, status_request, encrypt_then_mac, extended_master_secret,
+  //     signature_algorithms, supported_versions, psk_key_exchange_modes, key_share)
+  //   - encrypt_then_mac (type 22) empty extension included
+  //   - renegotiate extension suppressed (SCSV 0x00ff used in cipher list instead)
+  bool chrome_fingerprint_mode = false;
+
+  // chrome_extra_cipher_ids are appended verbatim to the ClientHello cipher list
+  // after all TLS 1.2 ciphers. Used to inject RSA suites and SCSV for fingerprinting.
+  uint16_t chrome_extra_cipher_ids[8] = {};
+  size_t chrome_extra_cipher_count = 0;
+
  private:
   friend RefCounted;
   ~ssl_ctx_st();
diff --git a/ssl/ssl_lib.cc b/ssl/ssl_lib.cc
index a1ba926f..c3609774 100644
--- a/ssl/ssl_lib.cc
+++ b/ssl/ssl_lib.cc
@@ -3133,6 +3133,35 @@ void SSL_CTX_set_grease_enabled(SSL_CTX *ctx, int enabled) {
   ctx->grease_enabled = !!enabled;
 }
 
+void SSL_CTX_set_client_custom_ext_cb(
+    SSL_CTX *ctx,
+    bool (*cb)(SSL *ssl, CBB *extensions, void *arg),
+    void *arg) {
+  ctx->client_custom_ext_cb = cb;
+  ctx->client_custom_ext_arg = arg;
+}
+
+void SSL_CTX_set_client_session_id_cb(
+    SSL_CTX *ctx,
+    void (*cb)(SSL *ssl, uint8_t session_id[32], void *arg),
+    void *arg) {
+  ctx->client_session_id_cb = cb;
+  ctx->client_session_id_arg = arg;
+}
+
+void SSL_CTX_enable_chrome_fingerprint_mode(SSL_CTX *ctx) {
+  ctx->chrome_fingerprint_mode = true;
+}
+
+void SSL_CTX_set_chrome_extra_ciphers(SSL_CTX *ctx, const uint16_t *ids,
+                                       size_t count) {
+  if (count > 8) count = 8;
+  ctx->chrome_extra_cipher_count = count;
+  for (size_t i = 0; i < count; i++) {
+    ctx->chrome_extra_cipher_ids[i] = ids[i];
+  }
+}
