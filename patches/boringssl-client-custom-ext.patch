diff --git a/include/openssl/ssl.h b/include/openssl/ssl.h
index 7d9499db..e6f02aca 100644
--- a/include/openssl/ssl.h
+++ b/include/openssl/ssl.h
@@ -5278,6 +5278,24 @@ OPENSSL_EXPORT void SSL_CTX_set_grease_enabled(SSL_CTX *ctx, int enabled);
 // permute extensions. For now, this is only implemented for the ClientHello.
 OPENSSL_EXPORT void SSL_CTX_set_permute_extensions(SSL_CTX *ctx, int enabled);
 
+// SSL_CTX_set_client_custom_ext_cb registers a callback invoked during
+// ClientHello assembly, after all standard extensions. The callback may append
+// additional TLS extensions by writing to |extensions| (a CBB whose parent
+// holds the extensions length-prefix). Return true to continue, false to abort.
+OPENSSL_EXPORT void SSL_CTX_set_client_custom_ext_cb(
+    SSL_CTX *ctx,
+    bool (*cb)(SSL *ssl, CBB *extensions, void *arg),
+    void *arg);
+
+// SSL_CTX_set_client_session_id_cb registers a callback invoked after the
+// legacy_session_id is filled with 32 random bytes during ClientHello
+// construction (TLS 1.3 compatibility mode). The callback may overwrite any
+// bytes of |session_id| in-place, e.g., to embed an identity marker.
+OPENSSL_EXPORT void SSL_CTX_set_client_session_id_cb(
+    SSL_CTX *ctx,
+    void (*cb)(SSL *ssl, uint8_t session_id[32], void *arg),
+    void *arg);
+
 // SSL_set_permute_extensions configures whether sockets on |ssl| should
 // permute extensions. For now, this is only implemented for the ClientHello.
 OPENSSL_EXPORT void SSL_set_permute_extensions(SSL *ssl, int enabled);
diff --git a/ssl/extensions.cc b/ssl/extensions.cc
index daf64357..ed0f4de5 100644
--- a/ssl/extensions.cc
+++ b/ssl/extensions.cc
@@ -4004,6 +4004,15 @@ bool ssl_add_clienthello_tlsext(SSL_HANDSHAKE *hs, CBB *out, CBB *out_encoded,
     last_was_empty = false;
   }
 
+  // Call user-registered custom extension callback (e.g., for REALITY).
+  if (ssl->ctx->client_custom_ext_cb != nullptr) {
+    if (!ssl->ctx->client_custom_ext_cb(ssl, &extensions,
+                                        ssl->ctx->client_custom_ext_arg)) {
+      OPENSSL_PUT_ERROR(SSL, ERR_R_INTERNAL_ERROR);
+      return false;
+    }
+  }
+
   // In cleartext ClientHellos, we add the padding extension to work around
   // bugs. We also apply this padding to ClientHelloOuter, to keep the wire
   // images aligned.
diff --git a/ssl/handshake_client.cc b/ssl/handshake_client.cc
index 901040c2..bef6f3b0 100644
--- a/ssl/handshake_client.cc
+++ b/ssl/handshake_client.cc
@@ -409,6 +409,13 @@ static enum ssl_hs_wait_t do_start_connect(SSL_HANDSHAKE *hs) {
     if (!RAND_bytes(hs->session_id.data(), hs->session_id.size())) {
       return ssl_hs_error;
     }
+    // Allow the application to overwrite bytes in the legacy_session_id
+    // (e.g., to embed an identity marker for the REALITY protocol).
+    if (ssl->ctx->client_session_id_cb != nullptr) {
+      assert(hs->session_id.size() == SSL_MAX_SSL_SESSION_ID_LENGTH);
+      ssl->ctx->client_session_id_cb(ssl, hs->session_id.data(),
+                                     ssl->ctx->client_session_id_arg);
+    }
   }
 
   ssl_early_data_reason_t reason = should_offer_early_data(hs);
diff --git a/ssl/internal.h b/ssl/internal.h
index 682acbf2..b0a86bea 100644
--- a/ssl/internal.h
+++ b/ssl/internal.h
@@ -3984,6 +3984,18 @@ struct ssl_ctx_st : public bssl::RefCounted<ssl_ctx_st> {
   // signal its sessions may be resumed across names in the server certificate.
   bool resumption_across_names_enabled : 1;
 
+  // client_custom_ext_cb, if non-null, is called during ClientHello assembly
+  // after all standard extensions. The callback may append additional TLS
+  // extensions to |extensions|. Returns true on success, false to abort.
+  bool (*client_custom_ext_cb)(SSL *ssl, CBB *extensions, void *arg) = nullptr;
+  void *client_custom_ext_arg = nullptr;
+
+  // client_session_id_cb, if non-null, is called after the legacy_session_id
+  // is filled with random bytes. The callback may overwrite any of the 32 bytes
+  // in |session_id| in-place (e.g., to embed an identity marker).
+  void (*client_session_id_cb)(SSL *ssl, uint8_t session_id[32], void *arg) = nullptr;
+  void *client_session_id_arg = nullptr;
+
  private:
   friend RefCounted;
   ~ssl_ctx_st();
diff --git a/ssl/ssl_lib.cc b/ssl/ssl_lib.cc
index a1ba926f..9350f664 100644
--- a/ssl/ssl_lib.cc
+++ b/ssl/ssl_lib.cc
@@ -3133,6 +3133,22 @@ void SSL_CTX_set_grease_enabled(SSL_CTX *ctx, int enabled) {
   ctx->grease_enabled = !!enabled;
 }
 
+void SSL_CTX_set_client_custom_ext_cb(
+    SSL_CTX *ctx,
+    bool (*cb)(SSL *ssl, CBB *extensions, void *arg),
+    void *arg) {
+  ctx->client_custom_ext_cb = cb;
+  ctx->client_custom_ext_arg = arg;
+}
+
+void SSL_CTX_set_client_session_id_cb(
+    SSL_CTX *ctx,
+    void (*cb)(SSL *ssl, uint8_t session_id[32], void *arg),
+    void *arg) {
+  ctx->client_session_id_cb = cb;
+  ctx->client_session_id_arg = arg;
+}
+
 void SSL_CTX_set_permute_extensions(SSL_CTX *ctx, int enabled) {
   ctx->permute_extensions = !!enabled;
 }
